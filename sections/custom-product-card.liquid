{%- comment -%}
  Section: Custom Product Card
  Renders a single product card for the Domaine take-home assignment.
  Product is selectable via Theme Editor.
{%- endcomment -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="page-width tw:flex tw:justify-left tw:px-4 section-{{ section.id }}-padding">
  {%- if section.settings.product != blank -%}
    {% render 'custom-card-product', card_product: section.settings.product, product_sale_text: section.settings.product_sale_text %}
  {%- endif -%}
</div>

<script src="{{ 'custom-product-card.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Custom Product Card",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Select product"
    },
    {
      "type": "text",
      "id": "product_sale_text",
      "label": "Sale badge text",
      "info": "Text that appears on the sale badge",
      "default": "On Sale!"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Custom Product Card",
      "category": "Custom"
    }
  ]
}
{% endschema %}